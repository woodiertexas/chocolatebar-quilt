{
	"schema_version": 1,
	"quilt_loader": {
		"group": "${maven_group}",
		"id": "chocolatebar",
		"version": "${version}",
		"metadata": {
			"name": "Chocolate Bar",
			"description": "A little mod that adds a chocolate bar to Minecraft.",
			"contributors": {
				"Me!": "woodiertexas"
			},
			"icon": "assets/chocolatebar/icon.png"
		},
		"intermediate_mappings": "net.fabricmc:intermediary",
		"entrypoints": {
			"init": [
				"io.github.woodiertexas.chocolatebar.ChocolateBar"
			]
		},
		"depends": [
			{
				"id": "quilt_loader",
				"versions": ">=${loader_version}"
			},
			{
				"id": "quilted_fabric_api",
				"versions": "${quilted_fabric_api_version}"
			},
			{
				"id": "minecraft",
				"versions": ">=${minecraft_version}"
			}
		]
	},
	"minecraft": {
		"environment": "*"
	}
}
